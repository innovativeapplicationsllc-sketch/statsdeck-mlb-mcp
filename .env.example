# ============================================================
# StatsDeck MCP Server — environment variable reference
# Copy to .env for local use. Never commit .env.
# ============================================================

# ---------------------------------------------------------------------------
# Transport (required)
# ---------------------------------------------------------------------------
# stdio  = local Claude Desktop (default)
# http   = Railway / remote deploy
MCP_TRANSPORT=stdio

# ---------------------------------------------------------------------------
# HTTP transport settings (only used when MCP_TRANSPORT=http)
# ---------------------------------------------------------------------------
MCP_HOST=0.0.0.0

# Local port — on Railway this is ignored; Railway injects PORT automatically
MCP_PORT=8000

# Bearer token protecting the /mcp endpoint.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Clients must send: Authorization: Bearer <this value>
# LEAVE UNSET to disable auth (local dev only — never deploy without this)
MCP_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Usage analytics (optional, additive — see README "Usage analytics")
# ---------------------------------------------------------------------------
# Postgres connection string. On Railway, add a Postgres database to the project
# and reference it on the StatsDeck service:  DATABASE_URL = ${{Postgres.DATABASE_URL}}
# Leave UNSET to disable analytics entirely (every event becomes a no-op; tools
# behave exactly as before). Never hardcode the value — always read from env.
# DATABASE_URL=postgresql://user:password@host:5432/railway

# Force-disable analytics even if DATABASE_URL is set (handy for CI/load tests).
# USAGE_ANALYTICS_DISABLED=

# ---------------------------------------------------------------------------
# Cache backend (pick one)
# ---------------------------------------------------------------------------

# Redis — recommended for Railway production.
# Set automatically by Railway when you add a Redis service (Upstash or Railway Redis).
# REDIS_URL=redis://default:password@host:6379

# Disk cache — for local dev with persistence across restarts.
# Leave empty to use in-memory cache (default for stateless deploys).
# CACHE_DIR=./cache/data

# ---------------------------------------------------------------------------
# Cache TTLs (seconds) — tune to taste
# ---------------------------------------------------------------------------
CACHE_TTL_STATCAST=10800    # 3 hours — Savant rate-limit buffer
CACHE_TTL_SEASON_STATS=3600 # 1 hour
CACHE_TTL_RECENT=900        # 15 minutes
CACHE_TTL_PLAYER_ID=604800  # 1 week — player IDs are permanent
CACHE_TTL_PITCHERS=1800     # 30 minutes
CACHE_TTL_INJURIES=600      # 10 minutes
