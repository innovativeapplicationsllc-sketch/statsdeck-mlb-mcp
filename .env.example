# Transport: "stdio" (local Claude Desktop) or "http" (remote deploy)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Cache directory (defaults to ./cache/data)
CACHE_DIR=

# Cache TTLs in seconds
CACHE_TTL_STATCAST=10800    # 3 hours — Savant rate-limit buffer
CACHE_TTL_SEASON_STATS=3600 # 1 hour
CACHE_TTL_RECENT=900        # 15 minutes
CACHE_TTL_PLAYER_ID=604800  # 1 week — player IDs rarely change
CACHE_TTL_PITCHERS=1800     # 30 minutes
CACHE_TTL_INJURIES=600      # 10 minutes

# Future: Redis URL when scaling out
# REDIS_URL=redis://localhost:6379/0
